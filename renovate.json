{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Presets from https://github.com/bcgov/nr-renovate",
  "extends": [
    "github>bcgov/renovate-config"
  ],
  "packageRules": [
    {
      "description": "Disable all Docker image patch updates",
      "matchManagers": [
        "dockerfile",
        "docker-compose",
        "kubernetes",
        "helm-values"
      ],
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "enabled": false
    },
    {
      "description": "Disable all Renovate updates for Eclipse Temurin base image, no auto-merge",
      "matchManagers": [
        "dockerfile"
      ],
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "eclipse-temurin"
      ],
      "enabled": false,
      "automerge": false
    }
  ]
}